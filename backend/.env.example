# ─── NextAuth (REQUIRED) ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── CORS (REQUIRED) ──────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ─── Stripe (REQUIRED for payments) ──────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# ─── Supabase (REQUIRED in production, omit for local stub mode) ──────────────
# Get from https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Email — Resend (REQUIRED in production) ──────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
GROUPME_INVITE_LINK=

# ─── Vercel Blob (REQUIRED for staff/sponsor image uploads) ───────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Google / Microsoft Forms Webhook ─────────────────────────────────────────
# Shared secret sent in Authorization: Bearer <secret> by your form trigger.
# Generate: openssl rand -base64 32
FORMS_WEBHOOK_SECRET=
# Points awarded per submission when the form does not include a 'points' field.
FORMS_DEFAULT_POINTS=1

# ─── Dev seed overrides (optional — only used by POST /api/dev/seed) ──────────
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=Admin1234!
SEED_MEMBER_EMAIL=member@test.com
SEED_MEMBER_PASSWORD=Member1234!
